# Cadena de conexión de la base de datos Neon (integración de Vercel).
# La obtienes en el panel de Vercel > Storage > tu base de datos Neon,
# o ejecutando: vercel env pull .env
DATABASE_URL="postgres://usuario:password@host/db?sslmode=require"

# Clave secreta para firmar los tokens de sesión (JWT).
# Genera una aleatoria y larga, por ejemplo con:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET="pon-aqui-una-cadena-larga-y-aleatoria"
